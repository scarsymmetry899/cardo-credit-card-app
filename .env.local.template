# Cardo Local Development Environment
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Anthropic API Key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Restrict CORS to your own domain in production
APP_ORIGIN=https://getcardo.in

# PaisaBazaar Publisher ID
PAISABAZAAR_AFF_ID=your-publisher-id

# BankBazaar Affiliate ID
BANKBAZAAR_AFF_ID=your-affiliate-id

# Supabase (for user accounts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
